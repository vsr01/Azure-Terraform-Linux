project      = "myapp"
environment  = "dev"
location     = "eastus2"
vm_size      = "Standard_D4as_v7"
admin_username = "azureuser"

ssh_public_key      = ""
ssh_public_key_path = "/Users/your-user/.ssh/azure-dev-vm.pub"
ssh_private_key_path = "~/.ssh/azure-dev-vm"
ssh_allowed_cidr     = "0.0.0.0/0"

vnet_address_space      = ["10.10.0.0/16"]
subnet_address_prefixes = ["10.10.1.0/24"]

tags = {
  owner = "your-name"
}

